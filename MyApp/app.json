{
  "expo": {
    "name": "ZuPay",
    "slug": "myapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/juha.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/juha.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "ZuPay needs camera access to scan QR codes for payments.",
        "NSFaceIDUsageDescription": "ZuPay uses Face ID to secure your transactions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/juha.png",
        "backgroundImage": "./assets/juha.png",
        "monochromeImage": "./assets/juha.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "package": "com.jubairyahya27.zupay"
    },
    "web": {
      "favicon": "./assets/juha.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "f95cf55c-f900-4846-95c4-50b2cb1da00d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f95cf55c-f900-4846-95c4-50b2cb1da00d"
    }
  }
}